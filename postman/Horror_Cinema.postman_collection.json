            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/reservations/99999", "host": ["{{baseUrl}}"], "path": ["api","reservations","99999"] }
          }
        }

      ]
    },

