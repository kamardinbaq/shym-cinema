# Copy this file to .env and fill in real values before running docker-compose.
# .env is gitignored — never commit real secrets.

# ── Required ────────────────────────────────────────────────
# JWT signing secret — must be at least 32 characters (256 bits).
# Generate a safe value with: openssl rand -hex 32
APP_JWT_SECRET=replace-me-with-at-least-32-character-secret-key

# ── Database (used when running the app outside Docker) ─────
DB_URL=jdbc:postgresql://localhost:5432/horror_cinema
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── Optional (defaults shown) ────────────────────────────────
# Comma-separated allowed CORS origins (no trailing slash)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Telegram bot token from @BotFather (leave blank to disable the bot)
TELEGRAM_BOT_TOKEN=

# Kaspi merchant IIN/BIN printed on fiscal receipts
KASPI_SELLER_IIN=990811301225

# Flat session price in KZT
SESSION_PRICE=3500

# JWT expiry in milliseconds (default: 24 hours)
JWT_EXPIRATION=86400000
